# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
API_PORT=8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Supabase: browser applications may use only the project URL and anon key.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-anon-key
# Backend only — never expose this value to the frontend or commit a real key.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_STORAGE_BUCKET=documents

# PostgreSQL / pgvector: use a restricted application role in production.
DATABASE_URL=postgresql://trustrag_app:change-me@localhost:5432/trustrag

# OpenAI-compatible provider. Store real credentials in a secret manager.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=replace-with-provider-key
LLM_CHAT_MODEL=replace-with-chat-model
LLM_EMBEDDING_MODEL=replace-with-embedding-model

# Security and operational configuration
MAX_UPLOAD_BYTES=26214400
ALLOWED_UPLOAD_TYPES=application/pdf
AUDIT_RETENTION_DAYS=365
PII_REDACTION_MODE=mask
